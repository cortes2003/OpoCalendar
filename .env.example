# ✅ OpoCalendar Environment Configuration
# Copia este archivo a .env.local y llena con tus valores

# ============ BACKEND CONFIGURATION ============
# Flask/FastAPI
SECRET_KEY=tu_clave_secreta_muy_larga_y_segura_min_32_caracteres
ENCRYPTION_KEY=tu_clave_encriptacion_fernet

# Database
DB_USER=opocalendar_user
DB_PASSWORD=contraseña_segura_db
DB_HOST=localhost
DB_PORT=3306
DB_NAME=opocalendar_db
DATABASE_URL=mysql://opocalendar_user:contraseña_segura_db@localhost:3306/opocalendar_db

# JWT Configuration
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ============ FRONTEND CONFIGURATION ============
# API URL - cambiar según entorno
VITE_API_URL=http://localhost:8000
# En producción: https://api.opocalendar.com

# Frontend URL (para CORS en backend)
FRONTEND_URL=http://localhost:5173
# En producción: https://app.opocalendar.com

# ============ ANDROID CONFIGURATION ============
# Build configuration
ANDROID_KEYSTORE_FILE=./keystore.jks
KEY_ALIAS=opocalendar_key
KEY_PASSWORD=tu_contraseña_keystore
STORE_PASSWORD=tu_contraseña_store

# App configuration
ANDROID_APP_ID=com.opocalendar.app
ANDROID_APP_NAME=OpoCalendar
ANDROID_MIN_SDK=21
ANDROID_TARGET_SDK=34

# ============ SECURITY CONFIGURATION ============
# Habilitar HTTPS
HTTPS=true

# Habilitar Security Headers
ENABLE_SECURITY_HEADERS=true

# Email configuration (para futuro)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@opocalendar.com

# ============ LOGGING CONFIGURATION ============
LOG_LEVEL=INFO
LOG_FILE=./logs/opocalendar.log

# ============ ENVIRONMENT ============
NODE_ENV=development
# En producción: production

# ============ FEATURES ============
ENABLE_NOTIFICATIONS=true
ENABLE_EMAIL_REMINDERS=false
ENABLE_ANALYTICS=false

# ============ RATE LIMITING ============
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000  # 15 minutos
